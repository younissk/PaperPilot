---
import Layout from '../../layouts/Layout.astro';
import { getAllResults, getQueryMetadata } from '../../lib/api';
import type { ReportData, Paper, AllResultsResponse, QueryMetadata } from '../../lib/types';

// Get the query_id from the URL
const { query_id } = Astro.params;

// Check for job parameter (from creation flow)
const jobId = Astro.url.searchParams.get('job');

// Fetch data server-side
let reportData: ReportData | null = null;
let papers: Paper[] = [];
let metadata: QueryMetadata | null = null;
let error: string | null = null;
let notFound = false;

if (query_id) {
  try {
    // Fetch all results in one call
    const results: AllResultsResponse = await getAllResults(query_id);
    reportData = results.report;
    papers = results.snowball?.papers || [];
    
    // Also get metadata for timestamps
    try {
      const metaResponse = await getQueryMetadata(query_id);
      metadata = metaResponse.metadata;
    } catch {
      // Metadata is optional, continue without it
    }
    
    if (!reportData && !jobId) {
      // No report and no job = 404
      notFound = true;
    }
  } catch (e) {
    const errorMessage = e instanceof Error ? e.message : 'Unknown error';
    if (errorMessage.includes('404') || errorMessage.includes('not found')) {
      if (!jobId) {
        notFound = true;
      }
    } else {
      error = errorMessage;
    }
  }
}

// Set 404 response status if not found
if (notFound) {
  Astro.response.status = 404;
}

// Prepare SEO data
const queryTitle = reportData?.query || query_id?.replace(/_/g, ' ') || 'Research Report';
const pageTitle = `Research Report: ${queryTitle}`;

// Extract first ~160 chars from introduction for meta description
const introText = reportData?.introduction || '';
const metaDescription = introText.length > 160 
  ? introText.substring(0, 157) + '...' 
  : introText || `Research report on ${queryTitle}`;

// Canonical URL (without query params)
const siteUrl = Astro.url.origin;
const canonicalUrl = `${siteUrl}/report/${query_id}`;

// Should we noindex? Only if generating or error
const shouldNoIndex = !reportData || !!error;

// Build JSON-LD structured data for SEO
const jsonLd = reportData ? {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  'headline': pageTitle,
  'description': metaDescription,
  'author': {
    '@type': 'Organization',
    'name': 'PaperPilot'
  },
  'datePublished': metadata?.report_generated_at || reportData.generated_at,
  'dateModified': metadata?.last_updated || reportData.generated_at,
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': canonicalUrl
  },
  'about': {
    '@type': 'Thing',
    'name': queryTitle
  },
  'numberOfPages': reportData.total_papers_used
} : undefined;

// Helper function to format citations in text
function formatCitations(text: string): string {
  // Replace [W123456789] style citations with links
  return text.replace(/\[([A-Za-z0-9_:-]+)\]/g, (match, paperId) => {
    const isOpenAlex = paperId.startsWith('W');
    const url = isOpenAlex 
      ? `https://openalex.org/${paperId}`
      : `https://openalex.org/search?q=${encodeURIComponent(paperId)}`;
    return `<a href="${url}" target="_blank" rel="noopener" class="citation" title="View paper">[${paperId}]</a>`;
  });
}
---

<Layout 
  title={pageTitle} 
  description={metaDescription}
  canonical={canonicalUrl}
  noindex={shouldNoIndex}
  jsonLd={jsonLd}
>
  <div class="container container-lg">
    {notFound && (
      <div class="not-found">
        <h1>Report Not Found</h1>
        <p class="text-muted">The report for "{query_id?.replace(/_/g, ' ')}" does not exist.</p>
        <div class="stack stack-md" style="margin-top: var(--spacing-lg);">
          <a href="/" class="btn btn-primary">Create New Report</a>
          <a href="/queries" class="btn btn-secondary">View Existing Reports</a>
        </div>
      </div>
    )}

    {error && !notFound && (
      <div class="alert alert-error">
        <strong>Error loading report:</strong> {error}
      </div>
    )}

    {!reportData && !notFound && !error && jobId && (
      <div id="generating-container" class="generating-state">
        <div class="progress-card">
          <h2>Generating Report</h2>
          <p class="text-muted">Your report for "{query_id?.replace(/_/g, ' ')}" is being generated...</p>
          <div class="progress-bar">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
          <p id="progress-message" class="text-sm text-muted">Starting...</p>
        </div>
      </div>
    )}

    {reportData && (
      <article class="report" itemscope itemtype="https://schema.org/ScholarlyArticle">
        <header class="report-header gradient-bg">
          <h1 itemprop="headline">Research Report: <span itemprop="about">{reportData.query}</span></h1>
          <div class="report-meta">
            <span class="badge">
              <time itemprop="datePublished" datetime={reportData.generated_at}>
                {new Date(reportData.generated_at).toLocaleDateString()}
              </time>
            </span>
            <span class="badge badge-secondary">{reportData.total_papers_used} papers used</span>
          </div>
        </header>

        <nav class="toc">
          <h3>Table of Contents</h3>
          <ul>
            <li><a href="#introduction">Introduction</a></li>
            <li>
              <a href="#current-research">Current Research</a>
              {reportData.current_research.length > 0 && (
                <ul>
                  {reportData.current_research.map((item, idx) => (
                    <li><a href={`#research-${idx}`}>{item.title}</a></li>
                  ))}
                </ul>
              )}
            </li>
            {reportData.open_problems.length > 0 && (
              <li><a href="#open-problems">Open Problems</a></li>
            )}
            <li><a href="#conclusion">Conclusion</a></li>
            <li><a href="#sources">Sources</a></li>
          </ul>
        </nav>

        <section id="introduction" class="report-section">
          <h2>Introduction</h2>
          <p set:html={formatCitations(reportData.introduction)} itemprop="description" />
        </section>

        <section id="current-research" class="report-section">
          <h2>Current Research</h2>
          {reportData.current_research.map((item, idx) => (
            <div id={`research-${idx}`} class="research-item">
              <h3>{item.title}</h3>
              <p set:html={formatCitations(item.summary)} />
              {item.paper_ids.length > 0 && (
                <div class="paper-refs">
                  <strong>Referenced papers:</strong>
                  <ul class="paper-id-list">
                    {item.paper_ids.map((paperId) => {
                      const card = reportData?.paper_cards.find(c => c.id === paperId);
                      const isOpenAlex = paperId.startsWith('W');
                      const url = isOpenAlex 
                        ? `https://openalex.org/${paperId}`
                        : `https://openalex.org/search?q=${encodeURIComponent(paperId)}`;
                      return (
                        <li>
                          <a href={url} target="_blank" rel="noopener" class="citation">[{paperId}]</a>
                          {card && <span class="paper-title">{card.title}</span>}
                        </li>
                      );
                    })}
                  </ul>
                </div>
              )}
            </div>
          ))}
        </section>

        {reportData.open_problems.length > 0 && (
          <section id="open-problems" class="report-section">
            <h2>Open Problems</h2>
            {reportData.open_problems.map((problem, idx) => (
              <div class="open-problem">
                <h3>{problem.title}</h3>
                <p set:html={formatCitations(problem.text)} />
                {problem.paper_ids.length > 0 && (
                  <div class="problem-sources">
                    <strong>Sources:</strong>
                    {problem.paper_ids.map((paperId) => {
                      const isOpenAlex = paperId.startsWith('W');
                      const url = isOpenAlex 
                        ? `https://openalex.org/${paperId}`
                        : `https://openalex.org/search?q=${encodeURIComponent(paperId)}`;
                      return (
                        <a href={url} target="_blank" rel="noopener" class="citation">[{paperId}]</a>
                      );
                    })}
                  </div>
                )}
              </div>
            ))}
          </section>
        )}

        <section id="conclusion" class="report-section">
          <h2>Conclusion</h2>
          <p set:html={formatCitations(reportData.conclusion)} />
        </section>

        <section id="sources" class="report-section">
          <h2>Sources</h2>
          <p class="text-muted text-sm">
            {papers.length} papers were analyzed for this report. Click on any paper to view it on OpenAlex.
          </p>
          
          {reportData.paper_cards.length > 0 && (
            <div class="paper-cards">
              {reportData.paper_cards.map((card) => {
                const isOpenAlex = card.id.startsWith('W');
                const url = isOpenAlex 
                  ? `https://openalex.org/${card.id}`
                  : `https://openalex.org/search?q=${encodeURIComponent(card.id)}`;
                return (
                  <a href={url} target="_blank" rel="noopener" class="paper-card" itemscope itemtype="https://schema.org/ScholarlyArticle">
                    <div class="paper-card-header">
                      <span class="paper-id">[{card.id}]</span>
                      {card.year && <span class="badge badge-secondary">{card.year}</span>}
                    </div>
                    <h4 itemprop="headline">{card.title}</h4>
                    <p class="paper-claim text-sm text-muted">{card.claim}</p>
                    <div class="paper-card-footer">
                      <span class="text-sm">{card.citation_count} citations</span>
                      {card.elo_rating && <span class="badge">ELO: {card.elo_rating.toFixed(0)}</span>}
                    </div>
                    {card.paradigm_tags.length > 0 && (
                      <div class="paper-tags">
                        {card.paradigm_tags.map((tag) => (
                          <span class="tag">{tag}</span>
                        ))}
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          )}
        </section>
      </article>
    )}
  </div>
</Layout>

{/* Client-side script for polling when generating */}
{!reportData && jobId && (
  <script define:vars={{ jobId, queryId: query_id }}>
    async function pollStatus() {
      const apiBaseUrl = import.meta.env?.API_BASE_URL || 'http://localhost:8000';
      
      try {
        const response = await fetch(`${apiBaseUrl}/api/pipeline/${jobId}`);
        const status = await response.json();
        
        const progressFill = document.getElementById('progress-fill');
        const progressMessage = document.getElementById('progress-message');
        
        if (progressMessage) {
          progressMessage.textContent = status.progress_message || status.status || 'Processing...';
        }
        
        if (progressFill && status.phase_total && status.phase_progress !== undefined) {
          const percent = (status.phase_progress / status.phase_total) * 100;
          progressFill.style.width = `${Math.min(percent, 100)}%`;
        }
        
        if (status.status === 'completed') {
          // Reload without job parameter to get the canonical URL
          window.location.href = `/report/${queryId}`;
          return;
        } else if (status.status === 'failed') {
          if (progressMessage) {
            progressMessage.textContent = `Failed: ${status.error || 'Unknown error'}`;
            progressMessage.style.color = 'var(--color-error)';
          }
          return;
        }
        
        // Continue polling
        setTimeout(pollStatus, 2000);
      } catch (e) {
        console.error('Polling error:', e);
        setTimeout(pollStatus, 2000);
      }
    }
    
    // Start polling
    pollStatus();
  </script>
)}

<style>
  .not-found {
    text-align: center;
    padding: var(--spacing-2xl);
  }

  .not-found h1 {
    color: var(--color-gray-600);
  }

  .generating-state {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 400px;
  }

  .progress-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl) var(--spacing-2xl);
    box-shadow: var(--shadow-md);
    text-align: center;
    max-width: 500px;
    width: 100%;
  }

  .progress-bar {
    height: 8px;
    background: var(--color-gray-200);
    border-radius: 4px;
    overflow: hidden;
    margin: var(--spacing-lg) 0;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-primary-500);
    transition: width 0.3s ease;
    width: 10%;
  }

  .report {
    max-width: 800px;
    margin: 0 auto;
  }

  .report-header {
    color: white;
    padding: var(--spacing-xl);
    border-radius: var(--radius-lg);
    margin-bottom: var(--spacing-xl);
  }

  .report-header h1 {
    color: white;
    margin: 0 0 var(--spacing-md) 0;
    font-size: var(--font-3xl);
  }

  .report-meta {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .report-meta .badge {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .toc {
    background: white;
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-200);
    margin-bottom: var(--spacing-xl);
  }

  .toc h3 {
    font-size: var(--font-base);
    margin-bottom: var(--spacing-md);
    color: var(--color-gray-600);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc > ul > li {
    margin-bottom: var(--spacing-sm);
  }

  .toc ul ul {
    margin-left: var(--spacing-lg);
    margin-top: var(--spacing-xs);
  }

  .toc ul ul li {
    font-size: var(--font-sm);
  }

  .toc a {
    color: var(--color-gray-700);
  }

  .toc a:hover {
    color: var(--color-primary-600);
  }

  .report-section {
    background: white;
    padding: var(--spacing-xl);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-lg);
    border: 1px solid var(--color-gray-200);
  }

  .report-section h2 {
    color: var(--color-primary-700);
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-primary-100);
  }

  .report-section p {
    line-height: 1.8;
  }

  .research-item {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-gray-100);
  }

  .research-item:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .research-item h3 {
    color: var(--color-gray-800);
    margin-bottom: var(--spacing-md);
  }

  .paper-refs {
    margin-top: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--color-gray-50);
    border-radius: var(--radius-md);
    font-size: var(--font-sm);
  }

  .paper-id-list {
    list-style: none;
    padding: 0;
    margin: var(--spacing-sm) 0 0 0;
  }

  .paper-id-list li {
    margin-bottom: var(--spacing-xs);
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
  }

  .paper-title {
    color: var(--color-gray-600);
  }

  .citation {
    display: inline;
    font-family: monospace;
    font-size: 0.85em;
    color: var(--color-primary-600);
    background: var(--color-primary-50);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    text-decoration: none;
  }

  .citation:hover {
    background: var(--color-primary-100);
    text-decoration: none;
  }

  .open-problem {
    margin-bottom: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: #fffaf0;
    border-left: 4px solid var(--color-warning);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .open-problem h3 {
    color: var(--color-warning);
    margin-bottom: var(--spacing-md);
  }

  .problem-sources {
    margin-top: var(--spacing-md);
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
    align-items: center;
  }

  .paper-cards {
    display: grid;
    gap: var(--spacing-md);
  }

  .paper-card {
    display: block;
    background: var(--color-gray-50);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-200);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .paper-card:hover {
    border-color: var(--color-primary-400);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .paper-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
  }

  .paper-id {
    font-family: monospace;
    font-size: var(--font-xs);
    color: var(--color-gray-500);
  }

  .paper-card h4 {
    font-size: var(--font-base);
    margin-bottom: var(--spacing-sm);
    color: var(--color-gray-800);
  }

  .paper-claim {
    margin-bottom: var(--spacing-sm);
  }

  .paper-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .paper-tags {
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
    margin-top: var(--spacing-sm);
  }

  .tag {
    font-size: var(--font-xs);
    padding: 0.1em 0.5em;
    background: var(--color-gray-200);
    border-radius: var(--radius-sm);
    color: var(--color-gray-600);
  }

  @media (max-width: 640px) {
    .report-header h1 {
      font-size: var(--font-2xl);
    }
  }
</style>
