---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Learn about PaperPilot - AI-powered academic literature discovery and analysis.">
  <div class="container container-lg">
    <div class="stack stack-xl">
      <h1>About PaperPilot</h1>
      
      <div class="card">
        <div class="stack stack-md">
          <p class="text-lg font-bold">AI-powered academic literature discovery</p>
          <p>
            PaperPilot helps researchers discover and analyze academic papers through intelligent
            search, ranking, visualization, and automated report generation.
          </p>
          
          <h3>Features</h3>
          <ul class="feature-list">
            <li>
              <strong>Semantic Search with Snowball Sampling</strong>
              <p class="text-muted text-sm">Discover relevant papers by iteratively expanding your search based on citations and references.</p>
            </li>
            <li>
              <strong>ELO-based Paper Ranking</strong>
              <p class="text-muted text-sm">AI-powered pairwise comparisons to rank papers by relevance to your research question.</p>
            </li>
            <li>
              <strong>Citation Graph Visualization</strong>
              <p class="text-muted text-sm">Explore relationships between papers through interactive citation network graphs.</p>
            </li>
            <li>
              <strong>Timeline Analysis</strong>
              <p class="text-muted text-sm">Visualize the evolution of research topics over time.</p>
            </li>
            <li>
              <strong>Paper Clustering</strong>
              <p class="text-muted text-sm">Automatically group papers by topic using advanced embedding techniques.</p>
            </li>
            <li>
              <strong>Automated Research Reports</strong>
              <p class="text-muted text-sm">Generate comprehensive literature review reports with citations and insights.</p>
            </li>
          </ul>
        </div>
      </div>
      
      <div class="card">
        <h3>How It Works</h3>
        <div class="stack stack-md">
          <div class="step">
            <span class="step-number">1</span>
            <div>
              <strong>Enter Your Query</strong>
              <p class="text-muted text-sm">Describe your research topic or question.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">2</span>
            <div>
              <strong>Snowball Search</strong>
              <p class="text-muted text-sm">We find relevant papers and expand via citations/references.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">3</span>
            <div>
              <strong>AI Ranking</strong>
              <p class="text-muted text-sm">Papers are compared pairwise and ranked by relevance.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">4</span>
            <div>
              <strong>Report Generation</strong>
              <p class="text-muted text-sm">A comprehensive report summarizes key findings and themes.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .feature-list {
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .feature-list li:last-child {
    border-bottom: none;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-primary-600);
    color: white;
    border-radius: 50%;
    font-weight: 600;
    flex-shrink: 0;
  }
</style>
