---
import Layout from '../layouts/Layout.astro';
import { listQueries, getQueryMetadata, slugifyQuery } from '../lib/api';

// Fetch queries server-side
let queries: string[] = [];
let error: string | null = null;

try {
  const response = await listQueries();
  queries = response.queries || [];
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load queries';
}
---

<Layout title="Previous Searches" description="View and explore your previous research queries.">
  <div class="container container-lg">
    <div class="stack stack-lg">
      <div class="header-row">
        <h1>Previous Searches</h1>
        <a href="/" class="btn btn-primary">New Search</a>
      </div>
      
      {error && (
        <div class="alert alert-error">
          <strong>Error:</strong> {error}
        </div>
      )}
      
      {!error && queries.length === 0 && (
        <div class="empty-state">
          <p class="text-muted">No previous queries found.</p>
          <p class="text-sm text-muted">Start a search to see your queries here.</p>
        </div>
      )}
      
      {!error && queries.length > 0 && (
        <div class="query-list">
          {queries.map((query) => {
            const slug = slugifyQuery(query);
            return (
              <a href={`/report/${slug}`} class="query-card">
                <span class="query-title">{query}</span>
                <span class="query-arrow">→</span>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-2xl);
  }

  .query-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .query-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-200);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .query-card:hover {
    border-color: var(--color-primary-400);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .query-title {
    font-weight: 500;
  }

  .query-arrow {
    color: var(--color-primary-600);
    font-size: var(--font-xl);
  }
</style>
