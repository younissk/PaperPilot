---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Discover Research Papers" description="Use PaperPilot's intelligent snowball search to find and explore relevant academic papers.">
  <div class="hero">
    <div class="container container-lg">
      <div class="stack stack-lg text-center">
        <h1 class="hero-title">Discover Research Papers</h1>
        <p class="hero-subtitle">
          Use our intelligent snowball search to find and explore relevant academic papers. 
          Enter your research query to get started.
        </p>
        
        <form id="search-form" class="search-form">
          <div class="search-row">
            <input 
              type="text" 
              name="query" 
              id="query-input"
              class="form-input form-input-lg search-input" 
              placeholder="e.g., LLM Based Recommendation Systems"
              required
            />
            <button type="submit" class="btn btn-primary btn-lg" id="submit-btn">
              Search
            </button>
          </div>
          
          <div class="options-toggle">
            <label class="switch-label">
              <input type="checkbox" name="pipeline" id="pipeline-toggle" checked />
              <span class="switch-text">Full Pipeline (Search + Rank + Report)</span>
            </label>
            <button type="button" class="btn-text" id="toggle-options">Show Advanced Options</button>
          </div>
          
          <div class="advanced-options" id="advanced-options" style="display: none;">
            <div class="options-card">
              <h4>Query Configuration</h4>
              <div class="options-grid">
                <div class="form-group">
                  <label class="form-label">Results per Query</label>
                  <input type="number" name="num_results" value="5" min="1" max="100" class="form-input" />
                </div>
                <div class="form-group">
                  <label class="form-label">Max Iterations</label>
                  <input type="number" name="max_iterations" value="5" min="1" max="20" class="form-input" />
                </div>
                <div class="form-group">
                  <label class="form-label">Max Accepted Papers</label>
                  <input type="number" name="max_accepted" value="200" min="10" class="form-input" />
                </div>
                <div class="form-group">
                  <label class="form-label">Top N Candidates</label>
                  <input type="number" name="top_n" value="50" min="5" class="form-input" />
                </div>
              </div>
              
              <h4 class="pipeline-options-title">ELO Ranking Configuration</h4>
              <div class="options-grid pipeline-only">
                <div class="form-group">
                  <label class="form-label">K-Factor</label>
                  <input type="number" name="k_factor" value="32" min="1" max="100" class="form-input" />
                </div>
                <div class="form-group">
                  <label class="form-label">Pairing Strategy</label>
                  <select name="pairing" class="form-input">
                    <option value="swiss">Swiss (Recommended)</option>
                    <option value="random">Random</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">ELO Concurrency</label>
                  <input type="number" name="elo_concurrency" value="5" min="1" max="20" class="form-input" />
                </div>
                <div class="form-group">
                  <label class="form-label">
                    <input type="checkbox" name="early_stop" checked />
                    Early Stop (when rankings stabilize)
                  </label>
                </div>
              </div>
              
              <h4 class="pipeline-options-title">Report Generation</h4>
              <div class="options-grid pipeline-only">
                <div class="form-group">
                  <label class="form-label">Top K Papers for Report</label>
                  <input type="number" name="report_top_k" value="30" min="1" class="form-input" />
                </div>
              </div>
            </div>
          </div>
        </form>
        
        <div id="progress-container" style="display: none;">
          <div class="progress-card">
            <h3 id="progress-title">Starting...</h3>
            <div class="progress-bar">
              <div class="progress-fill" id="progress-fill"></div>
            </div>
            <p id="progress-message" class="text-muted">Initializing...</p>
            <div id="progress-details" class="progress-details"></div>
          </div>
        </div>
        
        <div id="error-container" style="display: none;">
          <div class="alert alert-error">
            <strong>Error:</strong> <span id="error-message"></span>
          </div>
          <button type="button" class="btn btn-secondary" id="retry-btn">Try Again</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { startPipeline, getPipelineStatus, slugifyQuery } from '../lib/api';
  import type { PipelineResponse } from '../lib/types';
  import { JOB_POLLING_INTERVAL } from '../lib/config';

  const form = document.getElementById('search-form') as HTMLFormElement;
  const queryInput = document.getElementById('query-input') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const pipelineToggle = document.getElementById('pipeline-toggle') as HTMLInputElement;
  const toggleOptionsBtn = document.getElementById('toggle-options') as HTMLButtonElement;
  const advancedOptions = document.getElementById('advanced-options') as HTMLDivElement;
  const progressContainer = document.getElementById('progress-container') as HTMLDivElement;
  const progressTitle = document.getElementById('progress-title') as HTMLHeadingElement;
  const progressFill = document.getElementById('progress-fill') as HTMLDivElement;
  const progressMessage = document.getElementById('progress-message') as HTMLParagraphElement;
  const progressDetails = document.getElementById('progress-details') as HTMLDivElement;
  const errorContainer = document.getElementById('error-container') as HTMLDivElement;
  const errorMessage = document.getElementById('error-message') as HTMLSpanElement;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;

  let currentJobId: string | null = null;
  let pollingInterval: number | null = null;

  // Toggle advanced options
  toggleOptionsBtn.addEventListener('click', () => {
    const isHidden = advancedOptions.style.display === 'none';
    advancedOptions.style.display = isHidden ? 'block' : 'none';
    toggleOptionsBtn.textContent = isHidden ? 'Hide Advanced Options' : 'Show Advanced Options';
  });

  // Toggle pipeline-specific options visibility
  pipelineToggle.addEventListener('change', () => {
    const pipelineOnlyElements = document.querySelectorAll('.pipeline-only, .pipeline-options-title');
    pipelineOnlyElements.forEach((el) => {
      (el as HTMLElement).style.display = pipelineToggle.checked ? '' : 'none';
    });
  });

  // Form submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const query = queryInput.value.trim();
    if (!query) return;

    const formData = new FormData(form);
    
    try {
      setLoading(true);
      hideError();
      
      const request = {
        query,
        num_results: parseInt(formData.get('num_results') as string) || 5,
        max_iterations: parseInt(formData.get('max_iterations') as string) || 5,
        max_accepted: parseInt(formData.get('max_accepted') as string) || 200,
        top_n: parseInt(formData.get('top_n') as string) || 50,
        k_factor: parseFloat(formData.get('k_factor') as string) || 32,
        pairing: (formData.get('pairing') as 'swiss' | 'random') || 'swiss',
        early_stop: formData.has('early_stop'),
        elo_concurrency: parseInt(formData.get('elo_concurrency') as string) || 5,
        report_top_k: parseInt(formData.get('report_top_k') as string) || 30,
      };

      const response = await startPipeline(request);
      currentJobId = response.job_id;
      
      // Redirect to report page with job_id for progress tracking
      const slug = slugifyQuery(query);
      window.location.href = `/report/${slug}?job=${response.job_id}`;
      
    } catch (err) {
      showError(err instanceof Error ? err.message : 'Failed to start pipeline');
      setLoading(false);
    }
  });

  // Retry button
  retryBtn.addEventListener('click', () => {
    hideError();
    form.style.display = '';
  });

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    submitBtn.textContent = loading ? 'Starting...' : 'Search';
    queryInput.disabled = loading;
  }

  function showProgress() {
    form.style.display = 'none';
    progressContainer.style.display = 'block';
    errorContainer.style.display = 'none';
  }

  function showError(message: string) {
    errorContainer.style.display = 'block';
    errorMessage.textContent = message;
    progressContainer.style.display = 'none';
    form.style.display = 'none';
  }

  function hideError() {
    errorContainer.style.display = 'none';
  }

  function updateProgress(status: PipelineResponse) {
    const phaseNames: Record<string, string> = {
      'search': 'Searching for Papers',
      'ranking': 'Ranking Papers',
      'report': 'Generating Report',
    };

    const phase = status.phase || '';
    progressTitle.textContent = phaseNames[phase] || status.status || 'Processing...';
    progressMessage.textContent = status.progress_message || '';

    // Calculate progress percentage
    let percent = 0;
    if (status.phase_total && status.phase_progress !== undefined) {
      percent = (status.phase_progress / status.phase_total) * 100;
    }
    progressFill.style.width = `${Math.min(percent, 100)}%`;

    // Show phase details
    let details = '';
    if (phase === 'search') {
      details = `Step: ${status.phase_step_name || ''}`;
    } else if (phase === 'ranking') {
      details = `Matches: ${status.phase_progress || 0} / ${status.phase_total || '?'}`;
    } else if (phase === 'report') {
      details = `Step: ${status.phase_step_name || ''}`;
    }
    progressDetails.textContent = details;
  }

  function startPolling(query: string) {
    if (pollingInterval) {
      clearInterval(pollingInterval);
    }

    const poll = async () => {
      if (!currentJobId) return;

      try {
        const status = await getPipelineStatus(currentJobId);
        updateProgress(status);

        if (status.status === 'completed') {
          stopPolling();
          // Redirect to report page
          const slug = slugifyQuery(query);
          window.location.href = `/report/${slug}`;
        } else if (status.status === 'failed') {
          stopPolling();
          showError(status.error || 'Pipeline failed');
        }
      } catch (err) {
        // Continue polling on transient errors
        console.error('Polling error:', err);
      }
    };

    // Poll immediately, then every interval
    poll();
    pollingInterval = window.setInterval(poll, JOB_POLLING_INTERVAL);
  }

  function stopPolling() {
    if (pollingInterval) {
      clearInterval(pollingInterval);
      pollingInterval = null;
    }
  }
</script>

<style>
  .hero {
    min-height: calc(100vh - 55px - var(--spacing-lg) * 2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-primary-600);
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: var(--font-lg);
    color: var(--color-gray-500);
    max-width: 600px;
    margin: 0 auto;
  }

  .search-form {
    width: 100%;
    margin-top: var(--spacing-xl);
  }

  .search-row {
    display: flex;
    gap: var(--spacing-md);
  }

  .search-input {
    flex: 1;
  }

  .options-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--spacing-md);
  }

  .switch-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    cursor: pointer;
  }

  .switch-text {
    font-size: var(--font-sm);
    color: var(--color-gray-600);
  }

  .btn-text {
    background: none;
    border: none;
    color: var(--color-primary-600);
    cursor: pointer;
    font-size: var(--font-sm);
  }

  .btn-text:hover {
    text-decoration: underline;
  }

  .advanced-options {
    margin-top: var(--spacing-lg);
  }

  .options-card {
    background: white;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    text-align: left;
  }

  .options-card h4 {
    font-size: var(--font-sm);
    font-weight: 500;
    color: var(--color-gray-500);
    margin-bottom: var(--spacing-md);
  }

  .options-card h4:not(:first-child) {
    margin-top: var(--spacing-lg);
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .progress-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .progress-card h3 {
    margin-bottom: var(--spacing-md);
    color: var(--color-primary-600);
  }

  .progress-bar {
    height: 8px;
    background: var(--color-gray-200);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: var(--spacing-md);
  }

  .progress-fill {
    height: 100%;
    background: var(--color-primary-500);
    transition: width 0.3s ease;
    width: 0%;
  }

  .progress-details {
    font-size: var(--font-sm);
    color: var(--color-gray-600);
    margin-top: var(--spacing-sm);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .search-row {
      flex-direction: column;
    }

    .options-toggle {
      flex-direction: column;
      gap: var(--spacing-sm);
      align-items: flex-start;
    }
  }
</style>
