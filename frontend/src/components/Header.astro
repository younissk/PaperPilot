---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<header class="header">
  <div class="header-content">
    <a href="/" class="logo">PaperPilot</a>
    <div class="health-indicator" id="health-indicator">
      <span class="health-dot health-checking"></span>
      <span class="health-text">Checking...</span>
    </div>
    <nav class="nav">
      <a href="/queries" class:list={["nav-link", { active: currentPath === '/queries' }]}>
        Searches
      </a>
      <a href="/about" class:list={["nav-link", { active: currentPath === '/about' }]}>
        About
      </a>
    </nav>
  </div>
</header>

<script>
  // Health check on page load
  async function checkHealth() {
    const indicator = document.getElementById('health-indicator');
    if (!indicator) return;
    
    const dot = indicator.querySelector('.health-dot') as HTMLElement;
    const text = indicator.querySelector('.health-text') as HTMLElement;
    
    try {
      const apiBaseUrl = import.meta.env.API_BASE_URL || 'http://localhost:8000';
      const response = await fetch(`${apiBaseUrl}/api/health`);
      if (response.ok) {
        dot.classList.remove('health-checking', 'health-offline');
        dot.classList.add('health-online');
        text.textContent = 'API Online';
      } else {
        throw new Error('Not OK');
      }
    } catch {
      dot.classList.remove('health-checking', 'health-online');
      dot.classList.add('health-offline');
      text.textContent = 'API Offline';
    }
  }
  
  checkHealth();
</script>

<style>
  .header {
    background-color: var(--color-primary-600);
    height: 55px;
    display: flex;
    align-items: center;
  }

  .header-content {
    width: 100%;
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-md);
  }

  .logo {
    font-weight: 700;
    font-size: var(--font-xl);
    color: white;
    text-decoration: none;
    margin-right: var(--spacing-lg);
  }

  .logo:hover {
    text-decoration: none;
  }

  .health-indicator {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-right: auto;
  }

  .health-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .health-online {
    background-color: #7CE1D7;
  }

  .health-offline {
    background-color: #F3787A;
  }

  .health-checking {
    background-color: #F8D797;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .health-text {
    font-size: var(--font-xs);
    color: white;
    opacity: 0.9;
  }

  .nav {
    display: flex;
    height: 55px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-lg);
    background-color: white;
    color: var(--color-primary-600);
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .nav-link:hover {
    background-color: var(--color-gray-100);
    text-decoration: none;
  }

  .nav-link.active {
    background-color: var(--color-primary-50);
  }
</style>
